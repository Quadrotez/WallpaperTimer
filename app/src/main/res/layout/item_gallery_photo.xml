<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="130dp"
    android:layout_margin="3dp">

    <ImageView
        android:id="@+id/imgGalleryPhoto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="#CCCCCC" />

    <!-- Selection overlay -->
    <FrameLayout
        android:id="@+id/selectOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#885B6CF8"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/ivCheckmark"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:src="@android:drawable/checkbox_on_background"
        android:visibility="gone" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="#BB000000">

        <ImageButton
            android:id="@+id/btnGalleryCrop"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_crop"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Обрезать" />

        <ImageButton
            android:id="@+id/btnGalleryDelete"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Удалить" />
    </LinearLayout>
</FrameLayout>
